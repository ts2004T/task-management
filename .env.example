# App
PORT=3000
NODE_ENV=development
JWT_SECRET=replace_with_a_strong_secret

# Database
# Use ONE option below.

# Option A: Single connection URL (recommended for deployment platforms)
# DATABASE_URL=postgres://user:password@host:5432/task_management

# Option B: Discrete PostgreSQL settings (common for local development)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=task_management
